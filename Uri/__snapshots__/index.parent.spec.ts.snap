// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`mendly.Uri.parent > 'file path' 1`] = `"./folder"`;

exports[`mendly.Uri.parent > 'folder path' 1`] = `"./folder/sub"`;

exports[`mendly.Uri.parent > 'keeps scheme authority query fragment' 1`] = `"https://server.example.com/folder?alpha=1#frag"`;

exports[`mendly.Uri.parent > 'no path' 1`] = `"file:///"`;

exports[`mendly.Uri.parent > 'rootless absolute file' 1`] = `"/folder"`;

exports[`mendly.Uri.parent > 'single segment path' 1`] = `"."`;

exports[`mendly.Uri.parent > 'top level file' 1`] = `"."`;
