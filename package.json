{
	"name": "mendly",
	"version": "3.0.0-alpha.0",
	"description": "Mendly is a utility library for typescript and javascript mending the standard library.",
	"author": "Utily Contributors",
	"license": "MIT",
	"repository": "https://github.com/utily/mendly",
	"bugs": {
		"url": "https://github.com/utily/mendly/issues"
	},
	"homepage": "https://github.com/utily/mendly",
	"private": false,
	"type": "module",
	"types": "./dist/types/index.d.ts",
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/types/index.node.d.ts",
			"import": "./dist/index.node.js",
			"default": "./dist/index.node.js"
		}
	},
	"git": {
		"tagName": "v${version}"
	},
	"github": {
		"release": true
	},
	"scripts": {
		"lint": "eslint --max-warnings=0 '**/*.{ts,tsx}'",
		"fix": "eslint '**/*.{ts,tsx}' --fix",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"coverage": "vitest --coverage",
		"clean": "rimraf dist node_modules coverage",
		"verify": "npm run build && npm run test && npm run lint && npm audit --omit=dev"
	},
	"devDependencies": {
		"@types/node": "^24.10.0",
		"@typescript-eslint/eslint-plugin": "8.46.3",
		"@typescript-eslint/parser": "8.46.3",
		"@vitest/coverage-v8": "^4.0.7",
		"eslint": "^8.56.0",
		"eslint-plugin-prettierx": "github:utily/eslint-plugin-prettierx#utily-20231004",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"prettierx": "github:utily/prettierx#utily-20231004",
		"rimraf": "^6.1.0",
		"typescript": "5.9.3",
		"vite": "^7.1.12",
		"vitest": "^4.0.7"
	},
	"dependencies": {}
}
