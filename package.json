{
	"name": "mendly",
	"version": "3.1.1-beta.7",
	"description": "Mendly is a utility library for typescript and javascript mending the standard library.",
	"author": "Utily Contributors",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/utily/mendly.git"
	},
	"bugs": {
		"url": "https://github.com/utily/mendly/issues"
	},
	"homepage": "https://github.com/utily/mendly",
	"private": false,
	"type": "module",
	"types": "./dist/types/index.d.ts",
	"files": [
		"dist",
		"*.ts",
		"*/**/*.ts",
		"!*.spec.ts",
		"!*/**/*.spec.ts",
		"!test",
		"LICENSE",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/types/index.node.d.ts",
			"import": "./dist/index.node.js",
			"default": "./dist/index.node.js"
		}
	},
	"git": {
		"tagName": "v${version}"
	},
	"github": {
		"release": true
	},
	"scripts": {
		"lint": "biome format .",
		"format": "biome format --write .",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"coverage": "vitest --coverage",
		"clean": "rimraf dist node_modules coverage",
		"verify": "npm run build && npm run test && npm run lint && npm audit --omit=dev"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/node": "^24.10.0",
		"@vitest/coverage-v8": "^4.0.7",
		"rimraf": "^6.1.0",
		"typescript": "5.9.3",
		"vite": "^7.1.12",
		"vitest": "^4.0.7"
	},
	"dependencies": {}
}
